{
  "info": {
    "name": "Tekion APC API — AutoAdvisor AI",
    "description": "AutoAdvisor AI — Complete Tekion Automotive Partner Cloud API collection.\n\n## Setup\n\n1. Create an Environment in Postman with these variables:\n   - `base_url`: `https://api-sandbox.tekioncloud.com/openapi`\n   - `app_id`: your Tekion app ID\n   - `secret_key`: your Tekion secret key\n   - `dealer_id`: `techmotors_4_0` (sandbox)\n2. Start with **Auth → Get Token** to authenticate\n3. The token is auto-saved to `{{token}}` and used by all other requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api-sandbox.tekioncloud.com/openapi", "type": "string" },
    { "key": "app_id", "value": "your_app_id_here", "type": "string" },
    { "key": "secret_key", "value": "your_secret_key_here", "type": "string" },
    { "key": "dealer_id", "value": "techmotors_4_0", "type": "string" },
    { "key": "customer_id", "value": "", "type": "string" },
    { "key": "vehicle_id", "value": "", "type": "string" },
    { "key": "ro_id", "value": "", "type": "string" },
    { "key": "rc_id", "value": "", "type": "string" },
    { "key": "appointment_id", "value": "", "type": "string" },
    { "key": "transport_id", "value": "", "type": "string" },
    { "key": "shop_id", "value": "", "type": "string" },
    { "key": "vin", "value": "", "type": "string" },
    { "key": "next_fetch_key", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "description": "Authentication — generate and manage bearer tokens",
      "item": [{
        "name": "Get Token",
        "event": [{
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    var token = jsonData.data.access_token;",
              "    pm.collectionVariables.set('token', token);",
              "    console.log('Token saved:', token.substring(0, 20) + '...');",
              "} else {",
              "    console.log('Token request failed:', pm.response.status);",
              "}"
            ],
            "type": "text/javascript"
          }
        }],
        "request": {
          "method": "POST",
          "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
          "body": {
            "mode": "urlencoded",
            "urlencoded": [
              { "key": "app_id", "value": "{{app_id}}" },
              { "key": "secret_key", "value": "{{secret_key}}" }
            ]
          },
          "url": { "raw": "{{base_url}}/public/tokens", "host": ["{{base_url}}"], "path": ["public", "tokens"] },
          "description": "Generate a bearer token (expires ~24h). Rate-limited to 20 requests per 15 minutes."
        }
      }]
    },
    {
      "name": "2. Customers",
      "description": "Customer operations — search, get, create, update",
      "item": [
        {
          "name": "Search Customers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "app_id", "value": "{{app_id}}" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "dealer_id", "value": "{{dealer_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v4.0.0/customers?phone={{phone}}&search={{search}}&firstName={{first_name}}&lastName={{last_name}}&email={{email}}&customerType={{customer_type}}",
              "host": ["{{base_url}}"], "path": ["v4.0.0", "customers"],
              "query": [
                { "key": "phone", "value": "{{phone}}", "description": "Phone number (partial match)" },
                { "key": "search", "value": "{{search}}", "description": "General search" },
                { "key": "firstName", "value": "{{first_name}}", "description": "First name filter" },
                { "key": "lastName", "value": "{{last_name}}", "description": "Last name filter" },
                { "key": "email", "value": "{{email}}", "description": "Email filter" },
                { "key": "customerType", "value": "{{customer_type}}", "description": "INDIVIDUAL or BUSINESS" }
              ]
            },
            "description": "**Tier: Premium**\n\nSearch customers by phone, name, email, or general term. Returns matching records with linked vehicles."
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "app_id", "value": "{{app_id}}" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "dealer_id", "value": "{{dealer_id}}" }
            ],
            "url": { "raw": "{{base_url}}/v4.0.0/customers/{{customer_id}}", "host": ["{{base_url}}"], "path": ["v4.0.0", "customers", "{{customer_id}}"] },
            "description": "**Tier: Select**\n\nFetch a single customer with full bundle including vehicles, insurance, addresses, and communication preferences."
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "app_id", "value": "{{app_id}}" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "dealer_id", "value": "{{dealer_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\",\n  \"customerDetails\": {\n    \"customerType\": \"INDIVIDUAL\",\n    \"phoneCommunications\": [\n      {\n        \"phoneType\": \"MOBILE\",\n        \"phone\": { \"countryCode\": 1, \"localNumber\": \"5551234567\" },\n        \"usagePreference\": {\n          \"preferred\": true,\n          \"preferenceMapping\": { \"MARKETING\": \"NO\", \"TRANSACTION\": \"YES\" }\n        }\n      }\n    ],\n    \"name\": { \"firstName\": \"Jane\", \"lastName\": \"Smith\" }\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/v4.0.0/customers", "host": ["{{base_url}}"], "path": ["v4.0.0", "customers"] },
            "description": "**Tier: Open**\n\nCreate a new customer. Required: firstName, lastName, and at least one phoneCommunications entry."
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "app_id", "value": "{{app_id}}" },
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "dealer_id", "value": "{{dealer_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\",\n  \"customerDetails\": {\n    \"customerType\": \"INDIVIDUAL\",\n    \"phoneCommunications\": [\n      {\n        \"phoneType\": \"MOBILE\",\n        \"phone\": { \"countryCode\": 1, \"localNumber\": \"5559999999\" },\n        \"usagePreference\": {\n          \"preferred\": true,\n          \"preferenceMapping\": { \"MARKETING\": \"NO\", \"TRANSACTION\": \"YES\" }\n        }\n      }\n    ],\n    \"name\": { \"firstName\": \"Janet\", \"lastName\": \"Smith\" }\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/v4.0.0/customers/{{customer_id}}", "host": ["{{base_url}}"], "path": ["v4.0.0", "customers", "{{customer_id}}"] },
            "description": "**Tier: Open**\n\nUpdate an existing customer. Full replacement — GET first, modify, then PUT back."
          }
        }
      ]
    },
